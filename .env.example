# =============================================================================
# Auto Spare Parts ERP - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.

# -----------------------------------------------------------------------------
# PostgreSQL Configuration
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=autostockmanager
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Backend (FastAPI) Configuration
# -----------------------------------------------------------------------------
BACKEND_PORT=8000
SECRET_KEY=your-secret-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
ENVIRONMENT=development

# CORS origins (comma-separated for multiple origins)
CORS_ORIGINS=http://localhost:3000

# Database URL (constructed from PostgreSQL vars in docker-compose, override for local dev)
# DATABASE_URL=postgresql+asyncpg://postgres:changeme@localhost:5432/autostockmanager

# Redis URL (constructed in docker-compose, override for local dev)
# REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Frontend (Next.js) Configuration
# -----------------------------------------------------------------------------
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000
